# App
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postly:postly@localhost:5432/postly
DATABASE_URL_TEST=postgresql://postly:postly@localhost:5432/postly_test

# Redis
REDIS_URL=redis://localhost:6379

# JWT
ACCESS_TOKEN_SECRET=your-access-secret-min-32-chars
REFRESH_TOKEN_SECRET=your-refresh-secret-min-32-chars

# Encryption (must be exactly 64 hex characters = 32 bytes)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret

# OpenAI (platform fallback key)
OPENAI_API_KEY=sk-...

# Anthropic (platform fallback key)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (platform default key)
GROQ_API_KEY=gsk_...

# Twitter (for platform publishing)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
